{
  "name": "doost-app",
  "private": true,
  "version": "1.0.0",
  "homepage": "https://github.io/Doost",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:ghpages": "vite build --mode ghpages",
    "lint": "eslint .",
    "preview": "vite preview",
    "apk:sync": "npm run build && npx cap sync",
    "apk:build": "npm run apk:sync && cd android && gradlew assembleDebug && cd ..",
    "android:assets": "npx capacitor-assets generate --android",
    "android:dev": "npm run apk:build && adb install -r android\\app\\build\\outputs\\apk\\debug\\app-debug.apk",
    "predeploy": "npm run build:ghpages",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.12"
  }
}
